+bool audition_audio_preprocess_merged(
+    struct audition_ctx * ctx,
+    const std::vector<std::string> & audio_paths,
+    std::vector<audition_audio_chunk_mel> & chunks,
+    audition_merged_audio_info & merge_info) {
+
+    merge_info.merged_pcm.clear();
+    merge_info.segment_sample_boundaries.clear();
+    merge_info.segment_sample_lengths.clear();
+    merge_info.sr = COMMON_SAMPLE_RATE;
+    chunks.clear();
+
+    // Step 1: read all audio files → decode to PCM → concatenate
+    for (size_t i = 0; i < audio_paths.size(); i++) {
+        std::vector<uint8_t> file_buf;
+        if (!audition_read_binary_file(audio_paths[i].c_str(), &file_buf)) {
+            LOG_ERR("%s: failed to read audio file %s\n", __func__, audio_paths[i].c_str());
+            return false;
+        }
+
+        std::vector<float> pcm_i;
+        if (!decode_audio_from_buf(file_buf.data(), file_buf.size(), COMMON_SAMPLE_RATE, pcm_i)) {
+            LOG_ERR("%s: failed to decode audio file %s\n", __func__, audio_paths[i].c_str());
+            return false;
+        }
+
+        merge_info.segment_sample_boundaries.push_back(merge_info.merged_pcm.size());
+        merge_info.segment_sample_lengths.push_back(pcm_i.size());
+        merge_info.merged_pcm.insert(merge_info.merged_pcm.end(), pcm_i.begin(), pcm_i.end());
+    }
+
+    const size_t total_samples = merge_info.merged_pcm.size();
+    if (total_samples == 0) {
+        LOG_ERR("%s: no audio samples after merging\n", __func__);
+        return false;
+    }
+
+    LOG_INF("%s: merged %zu segments → %zu samples (%.2f sec)\n",
+            __func__, audio_paths.size(), total_samples,
+            (double)total_samples / COMMON_SAMPLE_RATE);
+
+    // Step 2: pad to 100ms boundary (1600 samples @ 16kHz)
+    const size_t CHUNK_ALIGN = 1600;
+    if (total_samples % CHUNK_ALIGN != 0) {
+        size_t padded = ((total_samples / CHUNK_ALIGN) + 1) * CHUNK_ALIGN;
+        merge_info.merged_pcm.resize(padded, 0.0f);
+    }
+
+    // Step 3: split by 30s (480000 samples) chunks, compute mel for each
+    const size_t MAX_CHUNK_SAMPLES = WHISPER_SAMPLE_RATE * WHISPER_CHUNK_SIZE; // 16000 * 30 = 480000
+    whisper_preprocessor::whisper_filters filters = audition_get_mel_filters(ctx);
+    if (filters.n_mel == 0 || filters.n_fft == 0) {
+        LOG_ERR("%s: mel filters not available\n", __func__);
+        return false;
+    }
+
+    const size_t padded_total = merge_info.merged_pcm.size();
+    for (size_t offset = 0; offset < padded_total; offset += MAX_CHUNK_SAMPLES) {
+        size_t chunk_len = std::min(MAX_CHUNK_SAMPLES, padded_total - offset);
+
+        // Align chunk to 100ms boundary
+        if (chunk_len % CHUNK_ALIGN != 0) {
+            chunk_len = ((chunk_len / CHUNK_ALIGN) + 1) * CHUNK_ALIGN;
+            if (offset + chunk_len > merge_info.merged_pcm.size()) {
+                merge_info.merged_pcm.resize(offset + chunk_len, 0.0f);
+            }
+        }
+
+        std::vector<whisper_preprocessor::whisper_mel> mel_out;
+        bool ok = whisper_preprocessor::preprocess_audio(
+            merge_info.merged_pcm.data() + offset,
+            chunk_len,
+            filters,
+            mel_out
+        );
+        if (!ok || mel_out.empty()) {
+            LOG_ERR("%s: failed to compute mel for chunk at offset %zu\n", __func__, offset);
+            return false;
+        }
+
+        audition_audio_chunk_mel cm;
+        cm.mel.nx = mel_out[0].n_len;
+        cm.mel.ny = mel_out[0].n_mel;
+        cm.mel.buf = std::move(mel_out[0].data);
+        cm.start_sample = (int)offset;
+        cm.end_sample = (int)(offset + chunk_len);
+
+        LOG_INF("%s: chunk [%zu..%zu) → mel %d frames x %d bins\n",
+                __func__, offset, offset + chunk_len, cm.mel.nx, cm.mel.ny);
+
+        chunks.push_back(std::move(cm));
+    }
+
+    LOG_INF("%s: total %zu chunks from %zu samples\n", __func__, chunks.size(), padded_total);
+    return true;
+}
+
+
+bool audition_audio_batch_encode_merged(
+    struct audition_ctx * ctx,
+    int n_threads,
+    const std::vector<audition_audio_chunk_mel> & chunks,
+    const audition_merged_audio_info & merge_info,
+    int n_embd,
+    std::vector<std::vector<float>> & segment_embeddings,
+    std::vector<int> & segment_n_tokens) {
+
+    segment_embeddings.clear();
+    segment_n_tokens.clear();
+
+    const int n_segments = (int)merge_info.segment_sample_boundaries.size();
+    segment_embeddings.resize(n_segments);
+    segment_n_tokens.resize(n_segments, 0);
+
+    // Disable streaming mode, clear KV cache for full-chunk forward
+    bool prev_streaming = ctx->whisper_streaming_mode;
+    ctx->whisper_streaming_mode = false;
+    audition_whisper_clear_kv_cache(ctx);
+
+    // Process each ≤30s chunk independently through the full Whisper encoder
+    for (size_t ci = 0; ci < chunks.size(); ci++) {
+        const auto & cm = chunks[ci];
+        const int chunk_start = cm.start_sample;
+        const int chunk_end = cm.end_sample;
+
+        // Build batch with this chunk's mel
+        audition_audio_f32_batch batch;
+        audition_audio_f32_ptr mel_copy(audition_audio_f32_init());
+        *mel_copy = cm.mel;
+        batch.entries.push_back(std::move(mel_copy));
+
+        // Compute output token count for this chunk
+        int n_tokens_out = audition_n_output_tokens(ctx, batch.entries[0].get());
+        std::vector<float> chunk_output(n_embd * n_tokens_out);
+
+        // Clear KV cache before each chunk forward (no streaming)
+        audition_whisper_clear_kv_cache(ctx);
+
+        if (!audition_audio_batch_encode(ctx, n_threads, &batch, chunk_output.data())) {
+            LOG_ERR("%s: failed to encode chunk %zu\n", __func__, ci);
+            ctx->whisper_streaming_mode = prev_streaming;
+            return false;
+        }
+
+        LOG_INF("%s: chunk %zu encoded → %d tokens x %d dims\n",
+                __func__, ci, n_tokens_out, n_embd);
+
+        // Split chunk output tokens into per-segment embeddings
+        // Token position ↔ sample position mapping:
+        //   mel_frame = sample_in_chunk / hop_length  (hop=160)
+        //   conv2_token = mel_frame / 2
+        //   pool_token = (conv2_token - 5) / 5 + 1  → but we use proportional split
+        //
+        // Python splits by calling _get_feat_extract_output_lengths per segment.
+        // Here we replicate the same formula on each segment's sample count.
+        // Python formula:
+        //   mel_frames = n_samples / hop_length + 1  (approx, from STFT)
+        //   conv_out = (mel_frames - 1) // 2 + 1     (conv2 stride=2, using //+1 to match torch conv1d_ph)
+        //   pool_out = (conv_out - 5) // 5 + 1       (AvgPool k=5 s=5)
+        //
+        // However, since convolutions run on the merged chunk, boundary tokens may blend.
+        // We use proportional allocation to split tokens, which is the safest approach:
+        //   For each segment, count its fraction of the chunk's total samples,
+        //   assign that fraction of output tokens.
+
+        struct SegInfo {
+            int seg_idx;
+            size_t sample_start_in_chunk;
+            size_t sample_len;
+        };
+        std::vector<SegInfo> segs_in_chunk;
+
+        for (int si = 0; si < n_segments; si++) {
+            size_t seg_start = merge_info.segment_sample_boundaries[si];
+            size_t seg_len = merge_info.segment_sample_lengths[si];
+            size_t seg_end = seg_start + seg_len;
+
+            // Check overlap with this chunk [chunk_start, chunk_end)
+            if ((int)seg_end <= chunk_start || (int)seg_start >= chunk_end) {
+                continue;
+            }
+            size_t overlap_start = std::max(seg_start, (size_t)chunk_start);
+            size_t overlap_end = std::min(seg_end, (size_t)chunk_end);
+            size_t overlap_len = overlap_end - overlap_start;
+
+            if (overlap_len > 0) {
+                segs_in_chunk.push_back({si, overlap_start - chunk_start, overlap_len});
+            }
+        }
+
+        if (segs_in_chunk.empty()) {
+            LOG_WRN("%s: chunk %zu has no overlapping segments\n", __func__, ci);
+            continue;
+        }
+
+        // Proportional token assignment
+        size_t total_overlap_samples = 0;
+        for (auto & s : segs_in_chunk) total_overlap_samples += s.sample_len;
+
+        int tokens_assigned = 0;
+        for (size_t si = 0; si < segs_in_chunk.size(); si++) {
+            int tok_count;
+            if (si == segs_in_chunk.size() - 1) {
+                tok_count = n_tokens_out - tokens_assigned;
+            } else {
+                tok_count = (int)((double)segs_in_chunk[si].sample_len / total_overlap_samples * n_tokens_out + 0.5);
+            }
+            if (tok_count < 0) tok_count = 0;
+
+            int seg_idx = segs_in_chunk[si].seg_idx;
+            size_t old_size = segment_embeddings[seg_idx].size();
+            segment_embeddings[seg_idx].resize(old_size + tok_count * n_embd);
+            std::memcpy(
+                segment_embeddings[seg_idx].data() + old_size,
+                chunk_output.data() + tokens_assigned * n_embd,
+                tok_count * n_embd * sizeof(float)
+            );
+            segment_n_tokens[seg_idx] += tok_count;
+            tokens_assigned += tok_count;
+
+            LOG_INF("%s: chunk %zu → segment %d: %d tokens (cumulative %d)\n",
+                    __func__, ci, seg_idx, tok_count, segment_n_tokens[seg_idx]);
+        }
+    }
+
+    // Restore streaming mode
+    ctx->whisper_streaming_mode = prev_streaming;
+    audition_whisper_clear_kv_cache(ctx);
+
+    LOG_INF("%s: batch encode complete, %d segments\n", __func__, n_segments);
+    for (int i = 0; i < n_segments; i++) {
+        LOG_INF("%s:   segment %d: %d tokens\n", __func__, i, segment_n_tokens[i]);
+    }
+
+    return true;
+}
