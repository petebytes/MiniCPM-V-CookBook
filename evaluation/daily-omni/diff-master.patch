+}
+
+// ==================== 音频 batch 预计算 ====================
+
+void omni_audio_batch_cache_clear(struct omni_context * ctx_omni) {
+    if (!ctx_omni) return;
+    auto & cache = ctx_omni->audio_batch_cache;
+    for (auto * embed : cache.segment_embeds) {
+        if (embed) omni_embed_free(embed);
+    }
+    cache.segment_embeds.clear();
+    cache.valid = false;
+    print_with_timestamp("omni_audio_batch_cache_clear: cleared %s\n", "ok");
+}
+
+struct omni_embed * omni_audio_batch_get_segment(struct omni_context * ctx_omni, int segment_idx) {
+    if (!ctx_omni || !ctx_omni->audio_batch_cache.valid) {
+        LOG_ERR("%s: audio batch cache not valid\n", __func__);
+        return nullptr;
+    }
+    auto & cache = ctx_omni->audio_batch_cache;
+    if (segment_idx < 0 || segment_idx >= (int)cache.segment_embeds.size()) {
+        LOG_ERR("%s: segment_idx %d out of range [0, %d)\n", __func__,
+                segment_idx, (int)cache.segment_embeds.size());
+        return nullptr;
+    }
+    return cache.segment_embeds[segment_idx];
+}
+
+bool omni_audio_batch_precompute(struct omni_context * ctx_omni,
+                                 const std::vector<std::string> & audio_paths) {
+    if (!ctx_omni || !ctx_omni->ctx_audio) {
+        LOG_ERR("%s: invalid context\n", __func__);
+        return false;
+    }
+
+    // Clear any previous cache
+    omni_audio_batch_cache_clear(ctx_omni);
+
+    int n_threads = ctx_omni->params->cpuparams.n_threads;
+    int n_embd = audition_n_mmproj_embd(ctx_omni->ctx_audio);
+
+    // Step 1: Merge all audio PCM → 30s chunk → mel
+    std::vector<audition_audio_chunk_mel> chunks;
+    audition_merged_audio_info merge_info;
+    if (!audition_audio_preprocess_merged(ctx_omni->ctx_audio, audio_paths, chunks, merge_info)) {
+        LOG_ERR("%s: audition_audio_preprocess_merged failed\n", __func__);
+        return false;
+    }
+    print_with_timestamp("omni_audio_batch_precompute: merged %d audio files → %d chunks, %d segments\n",
+                         (int)audio_paths.size(), (int)chunks.size(),
+                         (int)merge_info.segment_sample_boundaries.size());
+
+    // Step 2: Whisper encoder forward (full chunk, no streaming)
+    std::vector<std::vector<float>> segment_embeddings;
+    std::vector<int> segment_n_tokens;
+    if (!audition_audio_batch_encode_merged(ctx_omni->ctx_audio, n_threads, chunks, merge_info,
+                                            n_embd, segment_embeddings, segment_n_tokens)) {
+        LOG_ERR("%s: audition_audio_batch_encode_merged failed\n", __func__);
+        return false;
+    }
+
+    // Step 3: Wrap each segment's embedding into omni_embed and store in cache
+    int n_segments = (int)segment_embeddings.size();
+    auto & cache = ctx_omni->audio_batch_cache;
+    cache.segment_embeds.resize(n_segments, nullptr);
+
+    for (int i = 0; i < n_segments; i++) {
+        int n_tok = segment_n_tokens[i];
+        if (n_tok <= 0) {
+            LOG_WRN("%s: segment %d has 0 tokens, skipping\n", __func__, i);
+            cache.segment_embeds[i] = nullptr;
+            continue;
+        }
+
+        auto * embed = (omni_embed*)malloc(sizeof(omni_embed));
+        embed->embed = (float*)malloc(segment_embeddings[i].size() * sizeof(float));
+        if (!embed->embed) {
+            free(embed);
+            LOG_ERR("%s: malloc failed for segment %d\n", __func__, i);
+            omni_audio_batch_cache_clear(ctx_omni);
+            return false;
+        }
+        std::memcpy(embed->embed, segment_embeddings[i].data(),
+                     segment_embeddings[i].size() * sizeof(float));
+        embed->n_pos = n_tok;
+        cache.segment_embeds[i] = embed;
+
+        print_with_timestamp("omni_audio_batch_precompute: segment %d → %d tokens\n", i, n_tok);
+    }
+
+    cache.valid = true;
+    print_with_timestamp("omni_audio_batch_precompute: done, %d segments cached\n", n_segments);
+    return true;
+}
