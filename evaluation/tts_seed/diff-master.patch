+## 四、`omni-tts-eval.cpp` 主函数完整伪代码
+
+```cpp
+int main(int argc, char ** argv) {
+    // ========== 1. 命令行参数解析 ==========
+    // -m / --model-dir    : 模型目录
+    // --manifest          : TSV 清单文件路径
+    // --language          : zh / en
+    // --seed              : 随机种子（默认 42）
+    // --temperature       : LLM 采样温度（默认 0.3）
+    // --tts-temperature   : TTS 采样温度（默认 0.8）
+    // --max-audio-tokens  : TTS 最大 audio token 数（默认 2000）
+    // --teacher-forcing   : 启用 teacher-forcing（默认 true）
+    // --n-gpu-layers      : GPU offload 层数
+    // --t2w-device        : Token2Wav 设备（默认 "gpu:0"）
+
+    // ========== 2. 模型加载 ==========
+    // 设置 common_params
+    params.model = model_dir + "/MiniCPM-o-2_6-tts-F16.gguf";  // 或其他路径
+    params.tts_model = model_dir + "/MiniCPM-o-4_5-tts-step-audio-F16.gguf";
+    
+    // 调用 omni_init（同步模式，use_tts=true）
+    omni_context * ctx_omni = omni_init(&params, /*media_type=*/1, /*use_tts=*/true, 
+                                         tts_bin_dir, /*tts_gpu_layers=*/-1,
+                                         t2w_device);
+    ctx_omni->async = false;  // 非流式同步模式
+
+    // ========== 3. 解析 manifest ==========
+    auto samples = parse_manifest(manifest_path);
+
+    // ========== 4. 预加载 Token2Wav GGUF 模型（一次性） ==========
+    // Token2Wav 的 4 个 GGUF 路径从 tts_bin_dir 推断
+    // 在后续循环中只切换 prompt_bundle，不重新加载模型
+    
+    // ========== 5. 获取特殊 token IDs ==========
+    llama_token tts_bos_id = find_token(vocab, "<|tts_bos|>");
+    llama_token tts_eos_id = find_token(vocab, "<|tts_eos|>");
+    llama_token audio_start_id = find_token(vocab, "<|audio_start|>");
+    llama_token audio_end_id   = find_token(vocab, "<|audio_end|>");
+    // TTS 侧特殊 token:
+    int audio_bos_token_id = 151687;
+    int text_eos_token_id  = 151692;
+
+    // ========== 6. 循环推理 ==========
+    std::string prev_ref_audio = "";
+    omni_embed * audio_embed = nullptr;
+
+    for (int i = 0; i < samples.size(); i++) {
+        auto & sample = samples[i];
+        
+        // --- 6.1 切换参考音频（如需要） ---
+        if (sample.ref_audio_path != prev_ref_audio) {
+            // 释放旧的 audio embedding
+            if (audio_embed) omni_embed_free(audio_embed);
+            
+            // 加载新的 APM embedding
+            audio_embed = omni_audio_embed_make_with_filename(
+                ctx_omni->ctx_audio, params.cpuparams.n_threads, sample.ref_audio_path);
+            
+            // 切换 Token2Wav prompt_bundle
+            ctx_omni->t2w_session.switch_prompt_bundle(sample.bundle_dir);
+            
+            prev_ref_audio = sample.ref_audio_path;
+        }
+
+        // --- 6.2 清理 LLM KV cache ---
+        llama_memory_t mem_llm = llama_get_memory(ctx_omni->ctx_llama);
+        llama_memory_seq_rm(mem_llm, 0, 0, -1);
+        int n_past = 0;
+        
+        // --- 6.3 构造 prompt 并 Prefill + 收集 Hidden States ---
+        // 全局 hidden states 拼接缓冲区
+        std::vector<float> all_hidden_states;
+        std::vector<llama_token> all_token_ids;
+        int llm_n_embd = llama_n_embd(llama_get_model(ctx_omni->ctx_llama));
+        
+        // --- 片段 A: system prompt 前半 ---
+        std::string sys_prefix = "<|im_start|>system\nPlease imitate the reference voice";
+        auto tokens_sys = common_tokenize(ctx_omni->ctx_llama, sys_prefix, false, true);
+        float * hs_sys = nullptr;
+        eval_tokens_with_hidden(ctx_omni, &params, tokens_sys, params.n_batch, &n_past, hs_sys);
+        // 拼接到全局
+        append_hidden(all_hidden_states, hs_sys, tokens_sys.size(), llm_n_embd);
+        append_tokens(all_token_ids, tokens_sys);
+        free(hs_sys);
+        
+        // --- 片段 B: <|audio_start|> ---
+        auto tokens_audio_start = {audio_start_id};
+        float * hs_as = nullptr;
+        eval_tokens_with_hidden(ctx_omni, &params, tokens_audio_start, params.n_batch, &n_past, hs_as);
+        append_hidden(all_hidden_states, hs_as, 1, llm_n_embd);
+        append_tokens(all_token_ids, tokens_audio_start);
+        free(hs_as);
+        
+        // --- 片段 C: [ref_audio_embedding] ---
+        float * hs_audio = nullptr;
+        prefill_emb_with_hidden(ctx_omni, &params, audio_embed->embed, audio_embed->n_pos,
+                                params.n_batch, &n_past, hs_audio);
+        append_hidden(all_hidden_states, hs_audio, audio_embed->n_pos, llm_n_embd);
+        // audio embedding 没有 token IDs，用 placeholder
+        for (int j = 0; j < audio_embed->n_pos; j++) all_token_ids.push_back(-1);
+        free(hs_audio);
+        
+        // --- 片段 D: <|audio_end|> + 后续全部文本 ---
+        std::string suffix;
+        if (language == "zh") {
+            suffix = "<|audio_end|><|im_end|>\n<|im_start|>user\n读出下列文本内容。"
+                     + sample.infer_text 
+                     + "<|im_end|>\n<|im_start|>assistant\n<think>\n</think>\n<|tts_bos|>"
+                     + sample.infer_text 
+                     + "<|tts_eos|><|im_end|>";
+        }
+        auto tokens_suffix = common_tokenize(ctx_omni->ctx_llama, suffix, false, true);
+        float * hs_suffix = nullptr;
+        eval_tokens_with_hidden(ctx_omni, &params, tokens_suffix, params.n_batch, &n_past, hs_suffix);
+        append_hidden(all_hidden_states, hs_suffix, tokens_suffix.size(), llm_n_embd);
+        append_tokens(all_token_ids, tokens_suffix);
+        free(hs_suffix);
+        
+        // --- 6.4 提取 tts_bound 区间 ---
+        int tts_bos_pos = -1, tts_eos_pos = -1;
+        for (int j = (int)all_token_ids.size() - 1; j >= 0; j--) {
+            if (all_token_ids[j] == tts_bos_id && tts_bos_pos < 0) tts_bos_pos = j;
+            if (all_token_ids[j] == tts_eos_id && tts_eos_pos < 0) tts_eos_pos = j;
+        }
+        // tts_bound: [tts_bos_pos+1, tts_eos_pos)
+        int bound_start = tts_bos_pos + 1;
+        int bound_end = tts_eos_pos;
+        int n_tts_tokens = bound_end - bound_start;
+        
+        // 提取区间内的 hidden_states 和 token_ids
+        std::vector<float> tts_hidden(all_hidden_states.begin() + bound_start * llm_n_embd,
+                                       all_hidden_states.begin() + bound_end * llm_n_embd);
+        std::vector<llama_token> tts_token_ids(all_token_ids.begin() + bound_start,
+                                                all_token_ids.begin() + bound_end);
+        
+        // --- 6.5 构造 TTS condition ---
+        int tts_n_embd = llama_n_embd(llama_get_model(ctx_omni->ctx_tts_llama));  // 768
+        
+        // Step 1: emb_text(token_ids) → llm_embeds
+        std::vector<float> llm_embeds(n_tts_tokens * tts_n_embd);
+        for (int j = 0; j < n_tts_tokens; j++) {
+            tts_emb_text(ctx_omni, tts_token_ids[j], 
+                         llm_embeds.data() + j * tts_n_embd, tts_n_embd);
+        }
+        
+        // Step 2: projector_semantic(hidden_states) → projected
+        std::vector<float> projected(n_tts_tokens * tts_n_embd);
+        tts_projector_semantic(ctx_omni, tts_hidden.data(), n_tts_tokens, llm_n_embd,
+                               projected.data(), tts_n_embd);
+        
+        // Step 3: L2 normalize projected
+        normalize_l2_per_token(projected.data(), n_tts_tokens, tts_n_embd);
+        
+        // Step 4: tts_embeds = llm_embeds + projected
+        std::vector<float> tts_embeds(n_tts_tokens * tts_n_embd);
+        for (size_t j = 0; j < tts_embeds.size(); j++) {
+            tts_embeds[j] = llm_embeds[j] + projected[j];
+        }
+        
+        // Step 5: 构造完整 condition = [tts_embeds | text_eos_embed | audio_bos_embed]
+        // （Python 非流式路径：spk_embeds 为空，直接拼接）
+        std::vector<float> condition = tts_embeds;
+        
+        std::vector<float> text_eos_embed(tts_n_embd);
+        tts_emb_text(ctx_omni, text_eos_token_id, text_eos_embed.data(), tts_n_embd);
+        condition.insert(condition.end(), text_eos_embed.begin(), text_eos_embed.end());
+        
+        std::vector<float> audio_bos_embed(tts_n_embd);
+        tts_emb_text(ctx_omni, audio_bos_token_id, audio_bos_embed.data(), tts_n_embd);
+        condition.insert(condition.end(), audio_bos_embed.begin(), audio_bos_embed.end());
+        
+        int condition_length = n_tts_tokens + 2;
+        
+        // --- 6.6 TTS 自回归生成 ---
+        // 清空 TTS KV cache
+        llama_memory_t mem_tts = llama_get_memory(ctx_omni->ctx_tts_llama);
+        llama_memory_seq_rm(mem_tts, 0, 0, -1);
+        
+        // 保存 condition 用于 re-forward
+        ctx_omni->tts_condition_embeddings = condition;
+        ctx_omni->tts_condition_length = condition_length;
+        ctx_omni->tts_condition_n_embd = tts_n_embd;
+        ctx_omni->tts_condition_saved = true;
+        
+        // Prefill condition
+        int n_past_tts = 0;
+        prefill_with_emb_tts(ctx_omni, &params, condition.data(), 
+                             condition_length, params.n_batch, &n_past_tts);
+        
+        // 自回归生成 audio tokens
+        std::vector<int32_t> audio_tokens;
+        // 创建 TTS sampler（temperature=0.8, seed=42 等）
+        // 循环调用 sample_tts_token 直到 EOS 或达到上限
+        for (int t = 0; t < max_audio_tokens; t++) {
+            llama_token audio_tok = sample_tts_token(ctx_tts_sampler, ctx_omni, &params,
+                                                      &n_past_tts, &all_gen_tokens,
+                                                      &chunk_gen_tokens, t, 
+                                                      /*force_no_eos=*/(t < 10));
+            if (audio_tok == 6561) break;  // EOS = num_audio_tokens - 1
+            audio_tokens.push_back(audio_tok);
+            all_gen_tokens.push_back(audio_tok);
+            chunk_gen_tokens.push_back(audio_tok);
+        }
+        
+        // --- 6.7 Token2Wav → WAV ---
+        std::vector<float> pcm_wave;
+        ctx_omni->t2w_session.feed_tokens(audio_tokens.data(), audio_tokens.size(), 
+                                           true, pcm_wave);
+        write_wav_file(sample.output_wav_path, pcm_wave, 24000);
+        
+        // --- 6.8 重置 TTS 状态 ---
+        ctx_omni->tts_condition_saved = false;
+        ctx_omni->tts_all_generated_tokens.clear();
+    }
+    
+    // ========== 7. 清理 ==========
+    if (audio_embed) omni_embed_free(audio_embed);
+    omni_free(ctx_omni);
+    return 0;
+}
+```
